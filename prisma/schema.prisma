generator client {
  provider = "prisma-client-js"
}
 
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
 
// ── Enums ─────────────────────────────────────────────────────────────────────
 
enum UserRole {
  PRINCIPAL
  VICE_PRINCIPAL
  COORDINATOR
  ADMINISTRATOR
  CLASS_TEACHER
  SUBJECT_TEACHER
  TEMP_TEACHER
  INTERN
  OFFICE_STAFF
}
 
enum DayOfWeek {
  MON
  TUE
  WED
  THU
  FRI
  SAT
}
 
enum SubstitutionStatus {
  PENDING
  REQUESTED
  ACCEPTED
  DECLINED
  CANCELLED
  COMPLETED
}
 
enum SwapStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
  CANCELLED
}
 
enum Gender {
  MALE
  FEMALE
  OTHER
}
 
enum BloodGroup {
  A_POS
  A_NEG
  B_POS
  B_NEG
  O_POS
  O_NEG
  AB_POS
  AB_NEG
}
 
enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
  HALF_DAY
}
 
// ── Core tenant ───────────────────────────────────────────────────────────────
 
model School {
  id                 String              @id @default(uuid())
  name               String
  address            String?
  phone              String?
  email              String?
  subscriptionStatus String              @default("trial")
  config             Json                @default("{}")
  isActive           Boolean             @default(true)
  createdAt          DateTime            @default(now()) @db.Timestamptz
  updatedAt          DateTime            @updatedAt @db.Timestamptz
 
  users               User[]
  classes             Class[]
  subjects            Subject[]
  periods             PeriodDefinition[]
  timetableSlots      TimetableSlot[]
  timetableLocks      TimetableLock[]
  substitutions       Substitution[]
  swapRequests        SwapRequest[]
  students            Student[]
  announcements       Announcement[]
  resources           Resource[]
  resourceBookings    ResourceBooking[]
  attendances         Attendance[]
  attendanceSummaries AttendanceSummary[]
 
  @@map("schools")
}
 
// ── Staff / auth ──────────────────────────────────────────────────────────────
 
model User {
  id                String   @id @default(uuid())
  schoolId          String
  name              String
  email             String
  passwordHash      String
  role              UserRole
  avatarUrl         String?
  phone             String?
  preferredLanguage String   @default("en")
  fcmToken          String?
  isActive          Boolean  @default(true)
  failedLoginCount  Int      @default(0)
  lockedUntil       DateTime? @db.Timestamptz
  createdAt         DateTime @default(now()) @db.Timestamptz
  updatedAt         DateTime @updatedAt @db.Timestamptz
 
  school              School           @relation(fields: [schoolId], references: [id])
  refreshTokens       RefreshToken[]
  taughtSubjects      TeacherSubject[]
  timetableSlots      TimetableSlot[]
  timetableLocks      TimetableLock[]
  substitutionsAbsent Substitution[]   @relation("AbsentTeacher")
  substitutionsSub    Substitution[]   @relation("SubstituteTeacher")
  substitutionsAssign Substitution[]   @relation("AssignedBy")
  swapRequestsSent    SwapRequest[]    @relation("SwapRequester")
  swapRequestsRecv    SwapRequest[]    @relation("SwapReceiver")
  auditLogs           AuditLog[]
  announcements       Announcement[]
  resourceBookings    ResourceBooking[]
  attendancesMarked   Attendance[]     @relation("MarkedBy")
  classesAsTeacher    Class[]          @relation("ClassTeacher")
 
  @@unique([schoolId, email])
  @@index([schoolId])
  @@index([email])
  @@map("users")
}
 
// RESTORED: Removed by other agent — breaks auth.service.ts on next deploy
model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime @db.Timestamptz
  isRevoked Boolean  @default(false)
  createdAt DateTime @default(now()) @db.Timestamptz
 
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
 
  @@index([userId])
  @@map("refresh_tokens")
}
 
// ── Curriculum ────────────────────────────────────────────────────────────────
 
model Class {
  id             String   @id @default(uuid())
  schoolId       String
  name           String
  section        String?
  academicYear   String?
  classTeacherId String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now()) @db.Timestamptz
  updatedAt      DateTime @updatedAt @db.Timestamptz
 
  school        School              @relation(fields: [schoolId], references: [id])
  classTeacher  User?               @relation("ClassTeacher", fields: [classTeacherId], references: [id])
  timetableSlots TimetableSlot[]
  students       Student[]
  attendances    Attendance[]
  attendanceSummaries AttendanceSummary[]
 
  @@unique([schoolId, name, section])
  @@index([schoolId])
  @@index([classTeacherId])
  @@map("classes")
}
 
model Subject {
  id             String   @id @default(uuid())
  schoolId       String
  name           String
  code           String?
  // RESTORED: stripped by other agent — timetable generator needs these
  colorHex       String   @default("#7C6FFF")
  periodsPerWeek Int      @default(5)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now()) @db.Timestamptz
  updatedAt      DateTime @updatedAt @db.Timestamptz
 
  school         School           @relation(fields: [schoolId], references: [id])
  taughtSubjects TeacherSubject[]
  timetableSlots TimetableSlot[]
 
  @@unique([schoolId, name])
  @@index([schoolId])
  @@map("subjects")
}
 
// RESTORED: Removed by other agent — timetable generator needs teacher-subject mappings
model TeacherSubject {
  teacherId     String
  subjectId     String
  isPrimary     Boolean  @default(false)
  canSubstitute Boolean  @default(true)
  createdAt     DateTime @default(now()) @db.Timestamptz
 
  teacher Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  subject User    @relation(fields: [teacherId], references: [id], onDelete: Cascade)
 
  @@id([teacherId, subjectId])
  @@index([subjectId])
  @@map("teacher_subjects")
}
 
model PeriodDefinition {
  id           String   @id @default(uuid())
  schoolId     String
  periodNumber Int
  startTime    String
  endTime      String
  label        String?
  isBreak      Boolean  @default(false)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now()) @db.Timestamptz
  updatedAt    DateTime @updatedAt @db.Timestamptz
 
  school           School            @relation(fields: [schoolId], references: [id])
  timetableSlots   TimetableSlot[]
  resourceBookings ResourceBooking[]
  attendances      Attendance[]
 
  @@unique([schoolId, periodNumber])
  @@index([schoolId])
  @@map("period_definitions")
}
 
// ── Timetable ─────────────────────────────────────────────────────────────────
 
model TimetableSlot {
  id            String    @id @default(uuid())
  schoolId      String
  teacherId     String
  classId       String
  subjectId     String
  periodId      String
  dayOfWeek     DayOfWeek
  weekStartDate DateTime  @db.Date
  room          String?
  slotType      String    @default("regular")
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now()) @db.Timestamptz
  updatedAt     DateTime  @updatedAt @db.Timestamptz
 
  school        School           @relation(fields: [schoolId], references: [id])
  teacher       User             @relation(fields: [teacherId], references: [id])
  class         Class            @relation(fields: [classId], references: [id])
  subject       Subject          @relation(fields: [subjectId], references: [id])
  period        PeriodDefinition @relation(fields: [periodId], references: [id])
  substitutions Substitution[]
 
  @@unique([teacherId, periodId, dayOfWeek, weekStartDate])
  @@unique([classId, periodId, dayOfWeek, weekStartDate])
  @@index([schoolId])
  @@index([teacherId])
  @@index([classId])
  @@index([weekStartDate])
  @@map("timetable_slots")
}
 
model TimetableLock {
  id         String    @id @default(uuid())
  schoolId   String
  lockedById String
  reason     String?
  lockedAt   DateTime  @default(now()) @db.Timestamptz
  unlockedAt DateTime? @db.Timestamptz
 
  school    School @relation(fields: [schoolId], references: [id])
  lockedBy  User   @relation(fields: [lockedById], references: [id])
 
  @@index([schoolId])
  @@map("timetable_locks")
}
 
// ── Substitution & Swap ───────────────────────────────────────────────────────
 
model Substitution {
  id                  String             @id @default(uuid())
  schoolId            String
  timetableSlotId     String
  absentTeacherId     String
  substituteTeacherId String?
  date                DateTime           @db.Date
  status              SubstitutionStatus @default(PENDING)
  assignedById        String?
  requestSentAt       DateTime?          @db.Timestamptz
  respondedAt         DateTime?          @db.Timestamptz
  declineReason       String?
  notes               String?
  createdAt           DateTime           @default(now()) @db.Timestamptz
  updatedAt           DateTime           @updatedAt @db.Timestamptz
 
  school            School        @relation(fields: [schoolId], references: [id])
  timetableSlot     TimetableSlot @relation(fields: [timetableSlotId], references: [id])
  absentTeacher     User          @relation("AbsentTeacher", fields: [absentTeacherId], references: [id])
  substituteTeacher User?         @relation("SubstituteTeacher", fields: [substituteTeacherId], references: [id])
  assignedBy        User?         @relation("AssignedBy", fields: [assignedById], references: [id])
 
  @@index([schoolId])
  @@index([date])
  @@index([absentTeacherId])
  @@map("substitutions")
}
 
model SwapRequest {
  id              String     @id @default(uuid())
  schoolId        String
  requesterId     String
  receiverId      String
  requesterSlotId String
  receiverSlotId  String
  status          SwapStatus @default(PENDING)
  message         String?
  declineReason   String?
  expiresAt       DateTime   @db.Timestamptz
  respondedAt     DateTime?  @db.Timestamptz
  createdAt       DateTime   @default(now()) @db.Timestamptz
  updatedAt       DateTime   @updatedAt @db.Timestamptz
 
  school    School @relation(fields: [schoolId], references: [id])
  requester User   @relation("SwapRequester", fields: [requesterId], references: [id])
  receiver  User   @relation("SwapReceiver", fields: [receiverId], references: [id])
 
  @@index([schoolId])
  @@index([requesterId])
  @@index([receiverId])
  @@map("swap_requests")
}
 
// ── Students ──────────────────────────────────────────────────────────────────
 
model Student {
  id              String     @id @default(uuid())
  schoolId        String
  classId         String
  name            String
  rollNumber      String?
  admissionNumber String?
  dateOfBirth     DateTime?  @db.Date
  gender          Gender?
  bloodGroup      BloodGroup?
  photoUrl        String?
  address         String?
  parentName      String?
  parentPhone     String?
  emergencyContact Json?
  joinedDate      DateTime?  @db.Date
  isActive        Boolean    @default(true)
  createdAt       DateTime   @default(now()) @db.Timestamptz
  updatedAt       DateTime   @updatedAt @db.Timestamptz
 
  school              School              @relation(fields: [schoolId], references: [id])
  class               Class               @relation(fields: [classId], references: [id])
  attendances         Attendance[]
  attendanceSummaries AttendanceSummary[]
 
  @@unique([schoolId, rollNumber, classId])
  @@index([schoolId])
  @@index([classId])
  @@index([schoolId, name])
  @@map("students")
}
 
// ── Attendance (new feature — kept from other agent) ──────────────────────────
 
model Attendance {
  id         String           @id @default(uuid())
  schoolId   String
  studentId  String
  classId    String
  date       DateTime         @db.Date
  periodId   String?
  status     AttendanceStatus
  markedById String
  notes      String?
  createdAt  DateTime         @default(now()) @db.Timestamptz
  updatedAt  DateTime         @updatedAt @db.Timestamptz
 
  school    School            @relation(fields: [schoolId], references: [id])
  student   Student           @relation(fields: [studentId], references: [id])
  class     Class             @relation(fields: [classId], references: [id])
  period    PeriodDefinition? @relation(fields: [periodId], references: [id])
  markedBy  User              @relation("MarkedBy", fields: [markedById], references: [id])
 
  @@unique([studentId, date, periodId])
  @@index([schoolId])
  @@index([date])
  @@index([studentId])
  @@map("attendance")
}
 
model AttendanceSummary {
  id             String   @id @default(uuid())
  schoolId       String
  studentId      String
  classId        String
  month          Int
  year           Int
  totalDays      Int      @default(0)
  presentDays    Int      @default(0)
  absentDays     Int      @default(0)
  lateDays       Int      @default(0)
  excusedDays    Int      @default(0)
  halfDays       Int      @default(0)
  attendanceRate Float    @default(0)
  updatedAt      DateTime @updatedAt @db.Timestamptz
 
  school  School  @relation(fields: [schoolId], references: [id])
  student Student @relation(fields: [studentId], references: [id])
  class   Class   @relation(fields: [classId], references: [id])
 
  @@unique([studentId, month, year])
  @@index([schoolId])
  @@index([classId])
  @@map("attendance_summaries")
}
 
// ── Content & Resources ───────────────────────────────────────────────────────
 
model Announcement {
  id         String    @id @default(uuid())
  schoolId   String
  authorId   String
  title      String
  body       String
  targetRole UserRole?
  createdAt  DateTime  @default(now()) @db.Timestamptz
  updatedAt  DateTime  @updatedAt @db.Timestamptz
 
  school School @relation(fields: [schoolId], references: [id])
  author User   @relation(fields: [authorId], references: [id])
 
  @@index([schoolId])
  @@index([schoolId, createdAt])
  @@map("announcements")
}
 
model Resource {
  id        String   @id @default(uuid())
  schoolId  String
  name      String
  type      String
  capacity  Int?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz
 
  school   School            @relation(fields: [schoolId], references: [id])
  bookings ResourceBooking[]
 
  @@unique([schoolId, name])
  @@index([schoolId])
  @@map("resources")
}
 
model ResourceBooking {
  id            String    @id @default(uuid())
  schoolId      String
  resourceId    String
  periodId      String
  dayOfWeek     DayOfWeek
  weekStartDate DateTime  @db.Date
  bookedById    String
  purpose       String?
  createdAt     DateTime  @default(now()) @db.Timestamptz
 
  school    School           @relation(fields: [schoolId], references: [id])
  resource  Resource         @relation(fields: [resourceId], references: [id])
  period    PeriodDefinition @relation(fields: [periodId], references: [id])
  bookedBy  User             @relation(fields: [bookedById], references: [id])
 
  @@unique([resourceId, periodId, dayOfWeek, weekStartDate])
  @@index([schoolId])
  @@index([weekStartDate])
  @@map("resource_bookings")
}
 
// ── Audit ─────────────────────────────────────────────────────────────────────
 
model AuditLog {
  id         String   @id @default(uuid())
  schoolId   String
  userId     String?
  action     String
  entityType String?
  entityId   String?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now()) @db.Timestamptz
 
  user User? @relation(fields: [userId], references: [id])
 
  @@index([schoolId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}