{
  "name": "@educonnect/api",
  "version": "1.0.0",
  "private": true,
  "prisma": {
    "schema": "../../prisma/schema.prisma"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@educonnect/shared": "*",
    "@fastify/cookie": "^9.3.1",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/multipart": "^8.1.0",
    "@prisma/client": "^5.13.0",
    "argon2": "^0.31.2",
    "dotenv": "^17.4.2",
    "fastify": "^4.26.2",
    "firebase-admin": "^12.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "pino-pretty": "^11.0.0",
    "socket.io": "^4.7.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.0.0",
    "prisma": "^5.13.0",
    "tsx": "^4.10.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "plugins": [
    "expo-secure-store"
  ]
}
