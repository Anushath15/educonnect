{
  "expo": {
    "name": "EduConnect",
    "slug": "educonnect",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "scheme": "educonnect",
    "platforms": ["ios", "android"],
    "sdkVersion": "51.0.0",
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "android": {
      "package": "com.educonnect.app",
      "adaptiveIcon": {
        "backgroundColor": "#0F0F14"
      }
    },
    "ios": {
      "bundleIdentifier": "com.educonnect.app",
      "supportsTablet": false
    }
  }
}